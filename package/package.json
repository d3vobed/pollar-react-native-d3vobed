{
  "name": "@pollar/react-native",
  "version": "0.9.0",
  "description": "React Native package for Pollar authentication on mobile",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "react-native": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@pollar/core": "^0.9.0",
    "react": ">=18",
    "react-native": ">=0.76"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": false
    }
  },
  "dependencies": {
    "@pollar/core": "^0.9.0"
  },
  "devDependencies": {
    "@pollar/core": "^0.9.0",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-native": "^0.81.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
